// 找到 login 方法，修改为：
login: async (data: { username: string; password: string }) => {
  if (USE_MOCK) {
    return mockAuth.login(data);
  }
  // 使用 email 字段登录
  return api.post('/auth/login', { email: data.username.includes('@') ? data.username : data.username + '@example.com', password: data.password });
},
